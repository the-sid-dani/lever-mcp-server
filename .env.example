# lever-mcp-server — environment variables
# Copy this file to .env (gitignored) and fill in real values.
# Production values live in Google Secret Manager (project: ai-workflows-459123).

# === Required ===

# Lever API key — Lever admin > Integrations & API > API credentials
# Production: gcloud secrets versions access latest --secret=<name> --project=ai-workflows-459123
LEVER_API_KEY=

# Default Lever user ID used as `perform_as` fallback for write operations in single-tenant mode.
# Per-user resolution is planned for M3b via the multi-tenant resolver.
# Sid's user ID below as default.
LEVER_DEFAULT_USER_ID=eb1c3b07-33c7-4c7a-8702-ecd14efd2517

# Node runtime mode (development | production)
NODE_ENV=development

# HTTP server port (defaults to 8080 if unset)
PORT=8080

# === Optional / OAuth (Google broker) ===
# The server self-enables its OAuth 2.1 Authorization Server ONLY when both
# GOOGLE_OAUTH_CLIENT_ID and GOOGLE_OAUTH_CLIENT_SECRET are set. Otherwise OAuth
# is disabled and the server falls back to Cloud Run IAM (LEVER_DEFAULT_USER_ID).

# Google OAuth Web client ID (self-serve, no IT).
GOOGLE_OAUTH_CLIENT_ID=

# Matching Google OAuth client secret (kept server-side).
GOOGLE_OAUTH_CLIENT_SECRET=

# Public URL of this MCP server (token issuer / AS metadata base).
# Production: https://lever-mcp-201626763325.us-central1.run.app
MCP_PUBLIC_URL=

# Google Workspace hosted domain users must belong to (hd claim).
ALLOWED_HOSTED_DOMAIN=samba.tv

# === Other ===

# Anthropic API key — deployed as a Cloud Run secret but not currently referenced in src/.
# Reserved for future in-server LLM usage paths.
# ANTHROPIC_API_KEY=
